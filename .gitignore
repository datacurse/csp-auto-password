# De-itzmx tooling outputs (regenerable)
tools/output/

# Bundled proxy payloads (large; built by stage_version_payload.py)
versions/*/proxy/

# PyInstaller
build/
dist/

# Local backups of CSP install files
backups/

# Native build artifacts
tools/native/*.dll
tools/native/*.def

# Python cache
**/__pycache__/
